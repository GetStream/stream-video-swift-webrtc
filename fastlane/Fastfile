default_platform :ios
skip_docs

require 'json'
require 'net/http'
require 'shellwords'
require 'uri'

github_repo = ENV['GITHUB_REPOSITORY'] || 'GetStream/stream-video-swift-webrtc'
sdk_name = 'WebRTC'
modified_sdk_name = 'StreamWebRTC'
swift_package_path = '../Package.swift'
podspec_path = 'StreamWebRTC.podspec'

before_all do |lane|
  if is_ci
    setup_ci
    setup_git_config
  end
end

lane :code_review do
  sh('bundle exec rubocop Fastfile')
end

# Available options:
# - webrtc_branch: The branch of WebRTC to build from (optional)
#
# Example usage:
# bundle exec fastlane build webrtc_branch:"patch/m125"
lane :build do |options|
  code_review

  ['*.zip', '*.xcframework'].each { |f| sh("rm -rf #{f}") }
  xcframework_path = build_xcframework(branch: options[:webrtc_branch])
  modified_xcframework_path = clone_and_modify_xcframework(file_path: xcframework_path)

  match_me

  [xcframework_path, modified_xcframework_path].each { |path| sign_xcframework(file_path: path) }

  zip_xcframework_path = zip_xcframework(file_path: xcframework_path)
  zip_modified_xcframework_path = zip_xcframework(file_path: modified_xcframework_path)
  sh("swift package compute-checksum #{zip_xcframework_path}").strip
  sh("swift package compute-checksum #{zip_modified_xcframework_path}").strip
end

# Available options:
# - webrtc_xcframework_url: The URL to download WebRTC.xcframework.zip from (required)
#
# Example usage:
# bundle exec fastlane prepare_release_from_url webrtc_xcframework_url:"https://example.com/WebRTC.xcframework.zip"
lane :prepare_release_from_url do |options|
  UI.user_error!('You must specify a WebRTC.xcframework.zip URL') unless options[:webrtc_xcframework_url]

  code_review

  ['*.zip', '*.xcframework'].each { |f| sh("rm -rf #{f}") }
  xcframework_path = download_and_extract_xcframework(url: options[:webrtc_xcframework_url])
  modified_xcframework_path = clone_and_modify_xcframework(file_path: xcframework_path)

  match_me

  [xcframework_path, modified_xcframework_path].each { |path| sign_xcframework(file_path: path) }

  zip_xcframework_path = zip_xcframework(file_path: xcframework_path)
  zip_modified_xcframework_path = zip_xcframework(file_path: modified_xcframework_path)
  sh("swift package compute-checksum #{zip_xcframework_path}").strip
  sh("swift package compute-checksum #{zip_modified_xcframework_path}").strip
end

# Available options:
# - version: The version number for the release (required)
# - pre_release: Mark the Github release as a pre-release (optional)
# - webrtc_release_url: The upstream WebRTC release URL this release was created from (optional)
#
# Bumps Package.swift and the podspec, commits the version change, and publishes the SPM/GitHub release.
# Normal releases also publish CocoaPods; pre-releases stay SPM-only and can be promoted later with release_cocoapods.
#
# Example usage:
# bundle exec fastlane release version:125.6422.065 pre_release:false
lane :release do |options|
  UI.user_error!("You must specify an xcframework version") unless options[:version]
  version = sanitize_semver_version(version: options[:version])
  pre_release = [true, 'true'].include?(options[:pre_release])

  UI.user_error!("Tag for version #{version} already exists!") if git_tag_exists(tag: version)
  UI.success("Ignore the red warning above. Tag for version #{version} is alright!")

  check_unsafe_flags
  zip_xcframework_path = File.expand_path('WebRTC.xcframework.zip')
  zip_modified_xcframework_path = File.expand_path('StreamWebRTC.xcframework.zip')
  sh("swift package compute-checksum #{zip_xcframework_path}").strip
  checksum = sh("swift package compute-checksum #{zip_modified_xcframework_path}").strip

  update_swift_package(version: version, checksum: checksum)
  # CocoaPods is published later from the release tag, so keep the podspec version in the same bump commit.
  version_bump_podspec(path: podspec_path, version_number: version)

  sh('git add -A')
  sh("git commit -m 'Bump #{version}'")
  sh('git push')

  changelog = "Upgrade to WebRTC v#{version}\n\nChecksum: #{checksum}"
  webrtc_release_url = options[:webrtc_release_url].to_s.strip
  changelog += "\n\nCreated from: #{webrtc_release_url}" unless webrtc_release_url.empty?

  release_spm(
    version: version,
    changelog: changelog,
    upload_assets: [zip_xcframework_path, zip_modified_xcframework_path],
    pre_release: pre_release
  )

  release_cocoapods(version: version) unless pre_release
end

# Available options:
# - version: The normalized release version to publish (required)
# - changelog: The GitHub release changelog (required by this repo's release flow)
# - upload_assets: The zipped xcframework assets to attach to the GitHub release (required)
# - pre_release: Mark the GitHub release as a pre-release after creation (optional)
#
# Publishes only the GitHub/SPM release. It intentionally skips CocoaPods.
lane :release_spm do |options|
  UI.user_error!("You must specify an xcframework version") unless options[:version]
  UI.user_error!('You must specify upload assets') unless options[:upload_assets]

  publish_ios_sdk(
    # SPM and CocoaPods are intentionally split. This lane only creates the GitHub release and SPM assets.
    skip_pods: true,
    skip_spm: false,
    skip_branch_check: true,
    skip_git_status_check: false,
    github_repo: github_repo,
    sdk_names: [modified_sdk_name],
    podspec_names: [modified_sdk_name],
    version: options[:version],
    changelog: options[:changelog],
    upload_assets: options[:upload_assets]
  )

  pre_release = [true, 'true'].include?(options[:pre_release])
  mark_github_release_as_prerelease(github_repo: github_repo, tag: options[:version]) if pre_release
end

# Available options:
# - version: The release version to publish to CocoaPods (required)
#
# Publishes only CocoaPods. The pods workflow must checkout the release tag first so the local podspec matches
# the existing GitHub release assets.
lane :release_cocoapods do |options|
  UI.user_error!("You must specify an xcframework version") unless options[:version]
  version = sanitize_semver_version(version: options[:version])
  ensure_podspec_version(version: version)

  publish_ios_sdk(
    # The pods workflow checks out the release tag first, so this pushes that tag's podspec without rebuilding.
    skip_pods: false,
    skip_spm: true,
    skip_branch_check: true,
    skip_git_status_check: false,
    github_repo: github_repo,
    sdk_names: [modified_sdk_name],
    podspec_names: [modified_sdk_name],
    version: version
  )
end

private_lane :build_xcframework do |options|
  sh("./build_xcframework.sh #{options[:branch]}")
  current_path = File.expand_path('src/out_ios_libs/WebRTC.xcframework')
  new_path = "./#{File.basename(current_path)}"
  FileUtils.mv(current_path, new_path)
  File.expand_path(new_path)
end

private_lane :sanitize_semver_version do |options|
  version = options[:version].to_s.strip
  parts = version.split('.')

  if parts.empty? || parts.size > 3 || parts.any? { |part| part.empty? || !part.match?(/\A\d+\z/) }
    UI.user_error!("Version #{version} must contain one to three numeric dot-separated components")
  end

  (parts + Array.new(3 - parts.size, '0')).join('.')
end

private_lane :update_swift_package do |options|
  file_data = ''
  File.readlines(swift_package_path).each do |line|
    checksum_pattern = /(checksum: ")[a-z0-9]+(")/
    url_pattern = %r{(releases/download/)[.0-9]+(/)}

    formatted_line =
      if line.match(checksum_pattern)
        line.gsub(checksum_pattern, "\\1#{options[:checksum]}\\2")
      elsif line.match(url_pattern)
        line.gsub(url_pattern, "\\1#{options[:version]}\\2")
      else
        line
      end

    file_data << formatted_line
  end

  File.open(swift_package_path, 'w') { |file| file << file_data }
end

private_lane :ensure_podspec_version do |options|
  podspec_version = File.read(podspec_path).match(/spec.version\s*=\s*"([^"]+)"/)&.[](1)
  return if podspec_version == options[:version]

  UI.user_error!("Podspec version #{podspec_version} does not match release version #{options[:version]}")
end

private_lane :download_and_extract_xcframework do |options|
  url = options[:url]
  uri = URI.parse(url)
  unless uri.scheme == 'https' && uri.host == 'github.com' && uri.path.start_with?('/GetStream/webrtc/')
    UI.user_error!('WebRTC.xcframework.zip URL must be under https://github.com/GetStream/webrtc/')
  end

  work_dir = File.expand_path('downloaded_web_rtc')
  zip_path = File.join(work_dir, "#{sdk_name}.xcframework.zip")
  target_path = File.expand_path("#{sdk_name}.xcframework")

  FileUtils.rm_rf(work_dir)
  FileUtils.mkdir_p(work_dir)

  sh("curl --fail --location --output #{Shellwords.escape(zip_path)} #{Shellwords.escape(url)}")
  sh("ditto -x -k #{Shellwords.escape(zip_path)} #{Shellwords.escape(work_dir)}")

  xcframeworks = Dir.glob("#{work_dir}/**/#{sdk_name}.xcframework").select { |path| File.directory?(path) }
  if xcframeworks.size != 1
    UI.user_error!("Expected one #{sdk_name}.xcframework in the downloaded zip, found #{xcframeworks.size}")
  end

  FileUtils.rm_rf(target_path)
  FileUtils.mv(xcframeworks.first, target_path)
  FileUtils.rm_rf(work_dir)
  target_path
end

private_lane :clone_and_modify_xcframework do |options|
  old_framework_path = File.expand_path(options[:file_path])
  new_framework_path = old_framework_path.gsub(/#{sdk_name}/, modified_sdk_name)

  # Rename the framework itself
  sh("cp -R #{old_framework_path} #{new_framework_path}")

  # Rename all files with the old framework name with the new one
  ["#{sdk_name}.framework", "#{sdk_name}.dSYM", "#{sdk_name}.h", sdk_name].each do |file_name|
    Dir.glob("#{new_framework_path}/**/*").each do |old_file_path|
      next unless File.basename(old_file_path) == file_name

      new_file_path = old_file_path.reverse.sub(sdk_name.reverse, modified_sdk_name.reverse).reverse
      File.rename(old_file_path, new_file_path)
    end
  end

  # Replace all occurrences of the old framework name with the new one in the plist and modulemap files
  Dir.glob(["#{new_framework_path}/**/Info.plist", "#{new_framework_path}/**/module.modulemap"]).each do |file|
    sh("plutil -convert xml1 #{file}") if file.include?('Info.plist')
    old_text = File.read(file)
    new_text = old_text.gsub(/#{sdk_name}/, modified_sdk_name)
    File.open(file, 'w') { |f| f.puts(new_text) } if old_text != new_text
  end

  # Replace all imports of the old framework with the new one
  Dir.glob("#{new_framework_path}/**/*.h").each do |file|
    old_text = File.read(file)
    new_text = old_text.gsub(/import <#{sdk_name}/, "import <#{modified_sdk_name}")
    File.open(file, 'w') { |f| f.puts(new_text) } if old_text != new_text
  end

  # Rename the rpath for all the frameworks and update symlinks if required
  framework_paths = new_framework_path.include?('.xcframework') ? Dir.glob("#{new_framework_path}/**/*.framework") : [new_framework_path]
  framework_paths.each do |path|
    Dir.chdir(path) do
      if File.symlink?(modified_sdk_name)
        old_symlink = File.readlink(modified_sdk_name)
        new_symlink = old_symlink.reverse.sub(sdk_name.reverse, modified_sdk_name.reverse).reverse

        File.delete(modified_sdk_name)
        File.symlink(new_symlink, modified_sdk_name)
      end

      sh("install_name_tool -id @rpath/#{modified_sdk_name}.framework/#{modified_sdk_name} #{modified_sdk_name}")
    end
  end
  new_framework_path
end

private_lane :sign_xcframework do |options|
  team_id = File.read('Matchfile').match(/team_id\("(.*)"\)/)[1]
  sh("codesign --force --timestamp -v --sign 'Apple Distribution: Stream.io Inc (#{team_id})' #{options[:file_path]}")
end

private_lane :zip_xcframework do |options|
  zip_path = "#{options[:file_path]}.zip"
  sh("ditto -c -k --sequesterRsrc --keepParent #{options[:file_path]} #{zip_path}")
  zip_path
end

private_lane :mark_github_release_as_prerelease do |options|
  github_token = ENV.fetch('GITHUB_TOKEN', nil)
  UI.user_error!('GITHUB_TOKEN is required to mark the release as a pre-release') unless github_token

  encoded_tag = URI.encode_www_form_component(options[:tag])
  get_release_url = URI("https://api.github.com/repos/#{options[:github_repo]}/releases/tags/#{encoded_tag}")
  get_release_request = Net::HTTP::Get.new(get_release_url)
  get_release_request['Accept'] = 'application/vnd.github+json'
  get_release_request['Authorization'] = "Bearer #{github_token}"

  get_release_response = Net::HTTP.start(get_release_url.hostname, get_release_url.port, use_ssl: true) do |http|
    http.request(get_release_request)
  end

  unless get_release_response.kind_of?(Net::HTTPSuccess)
    UI.user_error!("Failed to fetch Github release #{options[:tag]}: #{get_release_response.body}")
  end

  release_id = JSON.parse(get_release_response.body).fetch('id')
  update_release_url = URI("https://api.github.com/repos/#{options[:github_repo]}/releases/#{release_id}")
  update_release_request = Net::HTTP::Patch.new(update_release_url)
  update_release_request['Accept'] = 'application/vnd.github+json'
  update_release_request['Authorization'] = "Bearer #{github_token}"
  update_release_request['Content-Type'] = 'application/json'
  update_release_request.body = JSON.dump(prerelease: true)

  update_release_response = Net::HTTP.start(update_release_url.hostname, update_release_url.port, use_ssl: true) do |http|
    http.request(update_release_request)
  end

  unless update_release_response.kind_of?(Net::HTTPSuccess)
    UI.user_error!("Failed to mark Github release #{options[:tag]} as a pre-release: #{update_release_response.body}")
  end
end

private_lane :appstore_api_key do
  @appstore_api_key ||= app_store_connect_api_key(
    key_id: 'MT3PRT8TB7',
    issuer_id: '69a6de96-0738-47e3-e053-5b8c7c11a4d1',
    key_content: ENV.fetch('APPSTORE_API_KEY', nil),
    in_house: false
  )
end

private_lane :match_me do
  custom_match(
    api_key: appstore_api_key,
    app_identifier: ['io.getstream.iOS.VideoDemoApp'], # dummy app to get the certificates
    readonly: true
  )
end
